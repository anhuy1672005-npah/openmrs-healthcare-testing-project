              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/location?q={{openmrs_location}}&v=default",
              "host": [
                "{{base_url}}/location?q={{openmrs_location}}&v=default"
              ]
            },
            "description": "Verify that the selected O2 login location can be found through the REST API.",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
