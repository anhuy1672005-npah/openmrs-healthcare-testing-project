    {
      "name": "Patient Resource",
      "item": [
        {
          "name": "API_PATIENT_001 - Search Patient by Keyword",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patient?q={{patient_search_keyword}}&v=default",
              "host": [
                "{{base_url}}/patient?q={{patient_search_keyword}}&v=default"
              ]
            },
            "description": "Verify patient search endpoint response structure. If a result exists, the first patient UUID is saved for the detail request.",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "",
                  "pm.test('Response contains results array', function () {",
                  "    pm.expect(data).to.have.property('results');",
                  "    pm.expect(data.results).to.be.an('array');",
                  "});",
                  "",
                  "if (data.results && data.results.length > 0 && data.results[0].uuid) {",
                  "    pm.environment.set('patient_uuid', data.results[0].uuid);",
                  "    pm.environment.set('patient_detail_expected', 'found');",
                  "} else {",
                  "    pm.environment.unset('patient_uuid');",
                  "    pm.environment.set('patient_detail_expected', 'not_found');",
                  "    console.warn('No patient result was found for patient_search_keyword. Patient detail request will use invalid_uuid as a controlled negative fallback.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "API_PATIENT_002 - Get Patient Detail by UUID from Search Result",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patient/{{effective_patient_uuid}}?v=full",
              "host": [
                "{{base_url}}/patient/{{effective_patient_uuid}}?v=full"
              ]
            },
            "description": "Verify patient detail endpoint. This request uses a patient UUID saved from the previous search. If no search result exists, it falls back to invalid_uuid and validates the not-found behavior.",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const patientUuid = pm.environment.get('patient_uuid');",
                  "if (patientUuid) {",
                  "    pm.variables.set('effective_patient_uuid', patientUuid);",
                  "    pm.variables.set('patient_detail_expected', 'found');",
                  "} else {",
                  "    pm.variables.set('effective_patient_uuid', pm.environment.get('invalid_uuid'));",
                  "    pm.variables.set('patient_detail_expected', 'not_found');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const expected = pm.environment.get('patient_detail_expected');",
                  "",
                  "pm.test('Patient detail response follows expected path', function () {",
                  "    if (expected === 'found') {",
                  "        pm.response.to.have.status(200);",
                  "        pm.response.to.be.json;",
                  "        const data = pm.response.json();",
                  "        pm.expect(data).to.have.property('uuid');",
                  "        pm.expect(data.uuid).to.eql(pm.environment.get('patient_uuid'));",
                  "    } else {",
                  "        pm.expect([400, 404, 500]).to.include(pm.response.code);",
                  "        pm.environment.set('patient_detail_observation', 'No patient UUID was available from search, so the request used fallback UUID and validated not-found/error behavior.');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "API_NEG_001 - Get Patient with Invalid UUID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patient/{{invalid_uuid}}?v=default",
              "host": [
                "{{base_url}}/patient/{{invalid_uuid}}?v=default"
              ]
            },
            "description": "Negative robustness test: request patient detail with an invalid UUID. Strict expectation is 400/404; current public O2 demo may return 500, which is documented as an observation.",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid UUID returns an error response', function () {",
                  "    pm.expect([400, 404, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 500) {",
                  "    pm.environment.set('invalid_uuid_observation', 'O2 public demo returned 500 for invalid patient UUID. This is documented as a backend robustness observation; strict APIs usually return 400 or 404.');",
                  "} else {",
                  "    pm.environment.set('invalid_uuid_observation', 'Invalid UUID returned expected client error status.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "API_NEG_002 - Unauthorized Patient Search",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "JSESSIONID=invalid-api-test-session"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patient?q={{patient_search_keyword}}&v=default",
              "host": [
                "{{base_url}}/patient?q={{patient_search_keyword}}&v=default"
              ]
            },
            "description": "Negative access-control test: request patient search without Basic Auth. Strict expectation is 401/403; the public O2 demo may return 200, which is documented as an environment/configuration observation.",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unauthorized/no-auth patient search behavior is captured', function () {",
                  "    pm.expect([200, 401, 403]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([401, 403].includes(pm.response.code)) {",
                  "    pm.environment.set('unauthorized_patient_search_observation', 'Unauthorized patient search was rejected as expected.');",
                  "} else {",
                  "    pm.response.to.be.json;",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('results');",
                  "    pm.environment.set('unauthorized_patient_search_observation', 'O2 public demo returned 200 for no-auth patient search. Document this as a public demo access-control/configuration observation.');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": []
}