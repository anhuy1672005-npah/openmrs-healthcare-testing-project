# OpenMRS O2 Selenium local configuration
# Copy this file to .env if you want to override default values.

OPENMRS_BASE_URL=https://o2.openmrs.org/openmrs
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=Admin123
OPENMRS_LOCATION=Registration Desk
OPENMRS_PATIENT_SEARCH=John

BROWSER=chrome
HEADLESS=false
SELENIUM_TIMEOUT=20

# Registration tests are optional because they may create data on the public demo.
RUN_REGISTRATION_TESTS=false
